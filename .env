# =============================================================================
# ASR Pipeline — 환경 설정
# =============================================================================

# Whisper 모델 (HuggingFace 이름: tiny/base/small/medium/large-v3/large-v3-turbo
#              또는 로컬 faster-whisper 디렉터리 경로)
ASR_MODEL=large-v3-turbo

# 음성 언어 (ko, en, ja, … / 비워두면 자동 감지)
ASR_LANGUAGE=ko

# 추론 디바이스 (auto / cpu / cuda)
ASR_DEVICE=cuda

# CTranslate2 연산 타입 (auto / int8 / int8_float16 / float16 / float32)
# int8_float16: int8 가중치 + float16 연산. float16 대비 VRAM ~0.6GB 절감으로
# 8GB GPU에서 Ollama 멘토+임베딩 모델과 공존 여지를 확보(모델 스래싱 완화). 정확도 영향 미미.
ASR_COMPUTE_TYPE=int8_float16

# Whisper beam size
ASR_BEAM_SIZE=1

# 이 값보다 낮은 STT 결과는 LLM에 전달하지 않음
ASR_MIN_LLM_CONFIDENCE=0.55

# HuggingFace 미러 (GFW 환경 등에서 사용)
HF_ENDPOINT=https://huggingface.co
TRANSFORMERS_OFFLINE=0

# =============================================================================
# Finetuning — 데이터셋 설정 (멀티 데이터셋)
# =============================================================================
# 쉼표로 구분된 HuggingFace Hub 데이터셋 이름 또는 로컬 audiofolder 경로 목록
FT_DATASET_NAMES=Bingsu/zeroth-korean,fsicoli/common_voice_22_0
# 각 데이터셋의 HuggingFace config 이름 (없으면 빈 문자열)
FT_DATASET_CONFIGS=,ko
# 각 데이터셋의 학습 split (+ 로 여러 split 병합 가능)
FT_DATASET_SPLIT_TRAINS=train,train+validation
# 각 데이터셋의 평가 split
FT_DATASET_SPLIT_TESTS=test,test
# 각 데이터셋의 오디오 컬럼명
FT_AUDIO_COLUMNS=audio,audio
# 각 데이터셋의 텍스트(정답) 컬럼명
FT_TEXT_COLUMNS=text,sentence
# 최대 레이블 토큰 길이 (초과 샘플 제거)
FT_MAX_LABEL_LENGTH=448

# =============================================================================
# Finetuning — 학습 하이퍼파라미터
# =============================================================================

# 체크포인트 저장 경로
FT_OUTPUT_DIR=./checkpoints
# 학습 에폭 수 (-1 이면 FT_MAX_STEPS 기준)
FT_EPOCHS=-1
# 디바이스당 학습 배치 크기 (large-v3-turbo: 인코더가 크므로 2로 제한)
FT_TRAIN_BATCH_SIZE=2
# 디바이스당 평가 배치 크기
FT_EVAL_BATCH_SIZE=4
# 그래디언트 누적 스텝 (유효 배치 = 2 × 8 = 16)
FT_GRAD_ACCUM_STEPS=8
# 학습률
FT_LEARNING_RATE=1e-5
# 웜업 스텝 (max_steps의 10% 수준)
FT_WARMUP_STEPS=200
# 최대 학습 스텝 (에폭 대신 스텝 기준으로 시간 제어)
FT_MAX_STEPS=2000
# 체크포인트 저장 주기 (스텝) — 평가보다 2배 주기로 디스크 절약
FT_SAVE_STEPS=500
# 평가 주기 (스텝) — 자주 평가하면 학습 시간 증가
FT_EVAL_STEPS=500
# 로그 출력 주기 (스텝)
FT_LOGGING_STEPS=50
# 최대 저장 체크포인트 수
FT_SAVE_TOTAL_LIMIT=3
# HuggingFace Hub 업로드 여부 (true/false)
FT_PUSH_TO_HUB=false

# =============================================================================
# Finetuning — CTranslate2 변환 설정
# =============================================================================

# 변환 결과 저장 경로
FT_CONVERTED_OUTPUT_DIR=./faster-whisper-finetuned
# 양자화 타입 (int8 / float16 / float32)
FT_QUANTIZATION=int8

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------

# 백엔드 오디오 수신 URI (client 모드)
WS_URI=ws://localhost:8080/audio

# ASR 서버 바인딩 (server 모드)
WS_SERVER_HOST=0.0.0.0
WS_SERVER_PORT=8765

# -----------------------------------------------------------------------------
# VAD
# -----------------------------------------------------------------------------

# RMS 에너지 임계값 (0.0 ~ 1.0)
VAD_THRESHOLD=0.4

# 이 시간(초) 동안 묵음이면 발화 종료로 판단
VAD_SILENCE_DURATION_S=0.8

# 최소 발화 길이 (짧은 노이즈 무시)
VAD_MIN_SPEECH_DURATION_S=0.3

# 최대 버퍼 길이(초) — 초과 시 강제 전사
VAD_MAX_BUFFER_DURATION_S=30.0

# 바지인(TTS 인터럽트) 최소 연속 발화 길이(ms). 클수록 보수적(잘 안 끊김).
# 멘토가 이 시간 이상 연속으로 말할 때만 AI TTS를 중단한다.
BARGE_IN_MIN_SPEECH_MS=350

# -----------------------------------------------------------------------------
# 오디오
# -----------------------------------------------------------------------------

AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION_MS=30

# -----------------------------------------------------------------------------
# TTS
# -----------------------------------------------------------------------------
TTS_VOICE=kf_bella        # kf_heart, km_blade, km_echo 등
TTS_LANG_CODE=k
TTS_ENGINE=sapi
TTS_SAPI_VOICE=junwoo
TTS_RATE=210
TTS_SPEED=1.0
TTS_SAMPLE_RATE=24000

# -----------------------------------------------------------------------------
# LLM 백엔드 전환 (ollama / groq)
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama
LLM_MODEL=driving-mentor
LLM_NUM_CTX=2048
LLM_NUM_PREDICT=120
LLM_TEMPERATURE=0.1

# 리슨리스트 요약 전용 모델. driving-mentor는 SYSTEM 프롬프트가 구조화 JSON 출력을
# 강제하므로 요약에 부적합하다. 일반 생성 모델(예: qwen2.5:7b, llama3.1:8b)을 받았다면
# 여기에 지정해 분리하라. 미설정 시 LLM_MODEL을 재사용하되 요약 호출 시 system 프롬프트로
# 멘토 SYSTEM을 덮어써 평문 요약을 받는다.
LLM_SUMMARY_MODEL=driving-mentor
# 요약 생성 토큰 한도 (1~3문장이면 256으로 충분)
LLM_SUMMARY_NUM_PREDICT=256
# LLM/임베딩 단일 요청 타임아웃(초). GPU 메모리 부족으로 Ollama가 모델을 스래싱해
# 호출이 무한정 멈추는 동결을 방지한다. 초과 시 해당 발화만 건너뛰고 계속 진행.
LLM_REQUEST_TIMEOUT_S=60

# -----------------------------------------------------------------------------
# 민감 정보 (API 키 등)는 .env.local 에 작성 — .gitignore 에 포함됨
# -----------------------------------------------------------------------------
