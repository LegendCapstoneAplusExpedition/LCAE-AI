# =============================================================================
# ASR Pipeline — 환경 설정
# =============================================================================

# Whisper 모델 (HuggingFace 이름: tiny/base/small/medium/large-v3
#              또는 로컬 faster-whisper 디렉터리 경로)
ASR_MODEL=base

# 음성 언어 (ko, en, ja, … / 비워두면 자동 감지)
ASR_LANGUAGE=ko

# 추론 디바이스 (auto / cpu / cuda)
ASR_DEVICE=auto

# CTranslate2 연산 타입 (auto / int8 / float16 / float32)
ASR_COMPUTE_TYPE=auto

# Whisper beam size
ASR_BEAM_SIZE=5

# HuggingFace 미러 (GFW 환경 등에서 사용)
HF_ENDPOINT=https://huggingface.co
TRANSFORMERS_OFFLINE=0

# =============================================================================
# Finetuning — 데이터셋 설정
# =============================================================================

# HuggingFace Hub 데이터셋 이름 또는 로컬 audiofolder 경로
FT_DATASET_NAME=Bingsu/zeroth-korean
# HuggingFace dataset config 이름 (ko, en, …)
FT_DATASET_CONFIG=""
# 학습/검증 split 이름 (+ 로 여러 split 병합 가능)
FT_DATASET_SPLIT_TRAIN=train
# 평가 split 이름
FT_DATASET_SPLIT_TEST=test
# 오디오 컬럼명
FT_AUDIO_COLUMN=audio
# 텍스트(정답) 컬럼명
FT_TEXT_COLUMN=text
# 최대 레이블 토큰 길이 (초과 샘플 제거)
FT_MAX_LABEL_LENGTH=448

# =============================================================================
# Finetuning — 학습 하이퍼파라미터
# =============================================================================

# 체크포인트 저장 경로
FT_OUTPUT_DIR=./checkpoints
# 학습 에폭 수 (-1 이면 FT_MAX_STEPS 기준)
FT_EPOCHS=3
# 디바이스당 학습 배치 크기 (GPU OOM 시 2~4로 줄이세요)
FT_TRAIN_BATCH_SIZE=8
# 디바이스당 평가 배치 크기
FT_EVAL_BATCH_SIZE=8
# 그래디언트 누적 스텝
FT_GRAD_ACCUM_STEPS=2
# 학습률
FT_LEARNING_RATE=1e-5
# 웜업 스텝
FT_WARMUP_STEPS=500
# 최대 학습 스텝 (-1 = FT_EPOCHS 기준)
FT_MAX_STEPS=-1
# 체크포인트 저장 주기 (스텝)
FT_SAVE_STEPS=1000
# 평가 주기 (스텝)
FT_EVAL_STEPS=1000
# 로그 출력 주기 (스텝)
FT_LOGGING_STEPS=25
# 최대 저장 체크포인트 수
FT_SAVE_TOTAL_LIMIT=3
# HuggingFace Hub 업로드 여부 (true/false)
FT_PUSH_TO_HUB=false

# =============================================================================
# Finetuning — CTranslate2 변환 설정
# =============================================================================

# 변환 결과 저장 경로
FT_CONVERTED_OUTPUT_DIR=./faster-whisper-finetuned
# 양자화 타입 (int8 / float16 / float32)
FT_QUANTIZATION=int8

# -----------------------------------------------------------------------------
# WebSocket
# -----------------------------------------------------------------------------

# 백엔드 오디오 수신 URI (client 모드)
WS_URI=ws://localhost:8080/audio

# ASR 서버 바인딩 (server 모드)
WS_SERVER_HOST=0.0.0.0
WS_SERVER_PORT=8765

# -----------------------------------------------------------------------------
# VAD
# -----------------------------------------------------------------------------

# RMS 에너지 임계값 (0.0 ~ 1.0)
VAD_THRESHOLD=0.4

# 이 시간(초) 동안 묵음이면 발화 종료로 판단
VAD_SILENCE_DURATION_S=0.8

# 최소 발화 길이 (짧은 노이즈 무시)
VAD_MIN_SPEECH_DURATION_S=0.3

# 최대 버퍼 길이(초) — 초과 시 강제 전사
VAD_MAX_BUFFER_DURATION_S=30.0

# -----------------------------------------------------------------------------
# 오디오
# -----------------------------------------------------------------------------

AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION_MS=30

# -----------------------------------------------------------------------------
# 민감 정보 (API 키 등)는 .env.local 에 작성 — .gitignore 에 포함됨
# -----------------------------------------------------------------------------
